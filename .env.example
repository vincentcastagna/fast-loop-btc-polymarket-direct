# Copy to .env or set these in your shell/User env.
# This direct bot does not use Simmer and cannot trade from a Simmer managed wallet.

# Polygon wallet private key that will sign Polymarket CLOB orders.
POLY_PRIVATE_KEY=

# Polymarket CLOB L2 credentials. Generate with:
#   python scripts/derive_api_creds.py
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Only needed for proxy/safe wallets. For a simple EOA wallet, leave empty.
# Common proxy mode examples use signature type 2 with a funder/proxy address.
POLY_SIGNATURE_TYPE=
POLY_FUNDER_ADDRESS=

# Hard live gate. The bot also requires --live and --yes-i-understand.
DIRECT_LIVE_CONFIRM=

# Optional direct-live caps. Strategy parameters stay in config.json.
# DIRECT_FASTLOOP_DIRECT_DAILY_BUDGET_USD=15
# DIRECT_FASTLOOP_DIRECT_MAX_DAILY_TRADES=3
